# ─── Database (Supabase Postgres — Transaction mode pooler for serverless) ────
# Get from: Supabase Dashboard → Project Settings → Database → Connection pooling
# Use "Transaction" mode URL for Vercel serverless compatibility
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# ─── Supabase (for candidates table) ─────────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://[project-ref].supabase.co
# Use service role key for server-side API routes (bypasses Row Level Security)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Gemini AI ────────────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
# Note: In Replit these are auto-set by the AI integration. On Vercel, set GEMINI_API_KEY.
GEMINI_API_KEY=AIza...


